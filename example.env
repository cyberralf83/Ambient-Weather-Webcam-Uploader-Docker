# =====================================================================
# Ambient Weather Webcam Uploader — environment template
# Copy to .env and fill in. The .env file is gitignored.
# =====================================================================

# ---------- Required ----------

# URL to your IP camera snapshot. If your camera needs auth, embed it
# in the URL (e.g., ?user=admin&pwd=...) or as a Cookie/Authorization
# header in ams-cam-upload.sh's wget call.
# Examples:
#   http://192.168.1.100/snapshot.jpg
#   http://192.168.1.100/cgi-bin/snapshot.cgi
#   http://192.168.1.120/action/snap?cam=0&user=admin&pwd=YOUR_CAM_PASSWORD
INPUT_IP=http://YOUR_CAMERA_IP/snapshot.jpg

# Ambient Weather FTP credentials (from ambientweather.net device panel)
USERNAME=your_ambient_weather_username
PASSWORD=your_ambient_weather_password

# ---------- Schedule ----------

# Easy mode — minutes between uploads (1-60). Wins over CRON_SCHEDULE if set.
INTERVAL_MINUTES=2

# Advanced mode — full 5-field cron expression. Only used when
# INTERVAL_MINUTES is unset. Examples:
#   */5 * * * *      = every 5 minutes
#   0 * * * *        = every hour, on the hour
#   0 */2 * * *      = every 2 hours
#   0 6 * * MON-FRI  = 6 AM weekdays only
#CRON_SCHEDULE=*/2 * * * *

# ---------- Timezone ----------

# Anything from /usr/share/zoneinfo. Examples: America/New_York,
# Europe/London, Asia/Tokyo, UTC
TZ=UTC

# ---------- Status web page ----------

# Built-in httpd serves a status page with last-upload status,
# counters, the latest image, and recent log lines.

# Host port published on the Docker host (used by docker-compose.portainer.yml).
# Change this if 8087 is already in use on your host.
STATUS_HOST_PORT=8087

# Enable/disable the status page entirely (default: true).
#STATUS_ENABLED=true

# Port the page is served on inside the container (used by docker-compose.yml
# for both host and container side; docker-compose.portainer.yml ignores
# the host side of this and uses STATUS_HOST_PORT instead). Default: 8080.
#STATUS_PORT=8080

# ---------- FTP target ----------

# Defaults are correct for Ambient Weather. Don't change unless directed.
#SERVER=ftp2.ambientweather.net
#PORT=21

# ---------- Reliability tuning (defaults shown) ----------

#MAX_RETRIES=3                 # Retry attempts for download and upload
#RETRY_DELAY=5                 # Seconds between retries
#TIMEOUT=30                    # Per-attempt timeout (seconds)
#MIN_IMAGE_SIZE=1024           # Reject downloaded files smaller than this (bytes)
#KEEP_IMAGES=5                 # Archived snapshots to keep on disk
#HEALTHCHECK_MAX_AGE=300       # Container is unhealthy if image is older than this (seconds)

# ---------- Image processing (optional, disabled by default) ----------

# Resize before upload (shrink only, preserves aspect ratio).
# Format: WIDTHxHEIGHT — e.g., 1920x1080, 1280x720, 640x480
#IMAGE_RESIZE=1920x1080

# JPEG quality, 1-100. Lower = smaller file, worse quality.
# If unset, original quality is preserved.
#IMAGE_QUALITY=85
