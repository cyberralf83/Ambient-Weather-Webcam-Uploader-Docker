# Required Configuration
# =====================

# URL to your IP camera snapshot
# Examples:
#   http://192.168.1.100/snapshot.jpg
#   http://192.168.1.100/cgi-bin/snapshot.cgi
#   https://mycamera.local/image.jpg
INPUT_IP=http://YOUR_CAMERA_IP/snapshot.jpg

# Ambient Weather FTP Credentials
USERNAME=your_ambient_weather_username
PASSWORD=your_ambient_weather_password

# Optional Configuration
# =====================

# FTP Server Settings (usually don't need to change these)
SERVER=ftp2.ambientweather.net
PORT=21

# Schedule Configuration
# Cron format: minute hour day month weekday
# Default: */2 * * * * (every 2 minutes)
# Examples:
#   */5 * * * *  = every 5 minutes
#   */15 * * * * = every 15 minutes
#   0 * * * *    = every hour
CRON_SCHEDULE=*/2 * * * *

# Retry Configuration
MAX_RETRIES=3           # Number of retry attempts for failed operations
RETRY_DELAY=5           # Seconds to wait between retry attempts

# Timeout Configuration
TIMEOUT=30              # Timeout in seconds for download/upload operations

# Image Validation
MIN_IMAGE_SIZE=1024     # Minimum valid image size in bytes (1KB)

# Storage Management
KEEP_IMAGES=5           # Number of archived images to keep

# Health Check Configuration
HEALTHCHECK_MAX_AGE=300 # Maximum age of image file in seconds (5 minutes)

# Image Processing (optional, disabled by default)
# Resize images before upload (shrinks only, preserves aspect ratio)
# Format: WIDTHxHEIGHT, e.g., 1920x1080, 1280x720, 640x480
#IMAGE_RESIZE=1920x1080

# JPEG quality (1-100, lower = smaller file, worse quality)
# If unset, original quality is preserved
#IMAGE_QUALITY=85

# Timezone Configuration
# Examples: America/New_York, Europe/London, Asia/Tokyo, UTC
TZ=UTC
